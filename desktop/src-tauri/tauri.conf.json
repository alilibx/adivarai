{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Adivari",
  "version": "0.1.0",
  "identifier": "ai.adivari.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000/surface"
  },
  "app": {
    "windows": [
      {
        "title": "Adivari",
        "label": "main",
        "width": 400,
        "height": 600,
        "minWidth": 340,
        "resizable": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
